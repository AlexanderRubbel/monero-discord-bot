# Discord Webhook (Server-Einstellungen -> Integrationen -> Webhooks -> Neu)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/YYYYYYYY

# Anzeigename in Discord-Embeds
WALLET_LABEL=Mein Monero Wallet

# Login fuer monero-wallet-rpc (intern, nur fuer Bot - frei waehlbar)
RPC_USER=botuser
RPC_PASS=ChangeMe-LongRandomString

# Pruefintervall in Sekunden (900 = 15 min)
CHECK_INTERVAL_SECONDS=900

# Remote-Node (oeffentlich, kein eigener monerod noetig)
# Alternativen: node.sethforprivacy.com:18089, xmr-node.cakewallet.com:18081
REMOTE_NODE=node.community.rino.io:18081
